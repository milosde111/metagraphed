# Public base URL of the Metagraphed backend API (default: https://api.metagraph.sh).
# Read by src/lib/metagraphed/config.ts as VITE_METAGRAPH_API_BASE.
# For a local backend: http://localhost:3000
VITE_METAGRAPH_API_BASE=https://api.metagraph.sh

# Optional icon proxy/resizer endpoint. When set, BrandIcon will prefer this
# source over GitHub avatars. The backend service (lives outside this repo)
# must implement:
#
#   GET {VITE_ICON_PROXY_URL}?host={domain}&size={px}&theme={light|dark}
#     → 200 image/png|svg (square, width/height >= size)
#     → 404 if no usable source found
#   Cache-Control: public, max-age=2592000, immutable + ETag
#
# Security: the frontend only forwards validated public http/https hostnames,
# but the proxy MUST independently reject localhost / IP literals / private +
# reserved DNS results / unsafe redirects, and rate-limit abusive requests.
#
# Leave blank to fall back to GitHub org avatars + the monogram tile.
VITE_ICON_PROXY_URL=
