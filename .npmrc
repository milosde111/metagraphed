# apps/ui depends on @tanstack/zod-adapter (peer: zod@^3.23.8) while also
# depending directly on zod@^4.4.3 for its own schemas — a real peer conflict,
# not a version-range typo (metagraphed-ui's own CI/deploy docs already needed
# `npm ci --legacy-peer-deps` for exactly this reason before it joined this
# workspace). Setting it here makes it the default for every `npm install`/
# `npm ci` in this repo rather than something each call site has to remember.
legacy-peer-deps=true
